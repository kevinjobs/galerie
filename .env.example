# .env.example
DATABASE_URL=postgresql://user:password@localhost:5432/database_name
# JWT_SECRET should be a strong, random string to ensure the security of your JWT tokens.
JWT_SECRET=your_jwt_secret_key
# EMAIL_HOST should be the SMTP server host.
EMAIL_HOST=smtp.example.com
# EMAIL_PORT should be the SMTP server port.
EMAIL_PORT=587
# EMAIL_USER should be your email address.
EMAIL_USER=your_email@example.com
# EMAIL_PASS should be your email password.
EMAIL_PASS=your_email_password
# SUPERUSER_EMAIL should be the email address of the superuser account.
SUPERUSER_EMAIL=admin@example.com
# SUPERUSER_PASSWORD should be a strong, random string to ensure the security of the superuser account.
SUPERUSER_PASSWORD=your_superuser_password